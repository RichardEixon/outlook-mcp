# ── Microsoft Azure App Registration ─────────────────────────────────────────
# Get these from: https://portal.azure.com → Azure Active Directory → App Registrations

# Your Azure App's Application (client) ID
MICROSOFT_CLIENT_ID=your-client-id-here

# Your Azure App's client secret value (not the secret ID)
MICROSOFT_CLIENT_SECRET=your-client-secret-here

# Tenant ID: use "common" for personal Microsoft/Outlook.com accounts
# For corporate/work accounts, use your organisation's Tenant ID
MICROSOFT_TENANT_ID=common

# ── OAuth Redirect URI ────────────────────────────────────────────────────────
# Must exactly match what you registered in Azure Portal
# For Replit: https://your-repl-name.your-username.repl.co/auth/callback
# For local:  http://localhost:3000/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# ── Token Storage ─────────────────────────────────────────────────────────────
# This is filled in automatically after you authenticate via /auth
# Copy the value shown and save it here (or as a Replit Secret)
MICROSOFT_REFRESH_TOKEN=

# ── Server Config ─────────────────────────────────────────────────────────────
PORT=3000

# Set to "true" to enable verbose MSAL / Graph API debug logging
DEBUG=false
